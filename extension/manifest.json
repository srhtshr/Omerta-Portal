{
  "manifest_version": 3,
  "name": "Omerta Portal",
  "version": "1.0.2",
  "description": "Shares Omerta family cooldowns and room chat through a shared dashboard.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://omertaportal.com/*",
    "https://*.omertaportal.com/*",
    "https://barafranca.nl/*",
    "https://*.barafranca.nl/*",
    "https://barafranca.pt/*",
    "https://*.barafranca.pt/*",
    "https://omerta.pt/*",
    "https://*.omerta.pt/*",
    "https://barafranca.com.tr/*",
    "https://*.barafranca.com.tr/*",
    "https://omerta.com.tr/*",
    "https://*.omerta.com.tr/*",
    "https://barafranca.com/*",
    "https://*.barafranca.com/*",
    "https://omerta.dm/*",
    "https://*.omerta.dm/*",
    "https://omerta-portal.onrender.com/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Omerta Portal v2.0",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://omertaportal.com/*",
        "https://*.omertaportal.com/*",
        "https://barafranca.nl/*",
        "https://*.barafranca.nl/*",
        "https://barafranca.pt/*",
        "https://*.barafranca.pt/*",
        "https://omerta.pt/*",
        "https://*.omerta.pt/*",
        "https://barafranca.com.tr/*",
        "https://*.barafranca.com.tr/*",
        "https://omerta.com.tr/*",
        "https://*.omerta.com.tr/*",
        "https://barafranca.com/*",
        "https://*.barafranca.com/*",
        "https://omerta.dm/*",
        "https://*.omerta.dm/*",
        "https://omerta-portal.onrender.com/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
{
  "manifest_version": 3,
  "name": "Omerta Family Cooldown Room",
  "version": "1.0.0",
  "description": "Shares Omerta family cooldowns and room chat through a shared dashboard.",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://barafranca.nl/*",
    "https://*.barafranca.nl/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://*:*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Omerta Family Cooldown Room v1.0",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://barafranca.nl/*",
        "https://*.barafranca.nl/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
